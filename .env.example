# ─────────────────────────────────────────────────────────
# Inference Router — environment variables
# Copy to .env and fill in the values you need.
# MOCK_MODE=true (default) means no credentials required.
# ─────────────────────────────────────────────────────────

# ── Routing ──────────────────────────────────────────────
MOCK_MODE=true         # set to false to call real APIs
LATENCY_WEIGHT=0.001   # $/second latency penalty

# ── Pricing refresh ───────────────────────────────────────
PRICING_REFRESH_INTERVAL=1800  # seconds between live price fetches (default 30 min)
AZURE_PRICING_REGION=eastus    # Azure region for price lookup (eastus = canonical)
AWS_PRICING_LOCATION=US East (N. Virginia)  # AWS Bedrock pricing location

# ── AWS Bedrock ──────────────────────────────────────────
# 1. AWS Console → IAM → create user with AmazonBedrockFullAccess
# 2. Generate an access key for that user
# 3. Enable Claude 3 Haiku in Bedrock → Model Access (us-east-1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── GCP Vertex AI ────────────────────────────────────────
# 1. GCP Console → APIs → enable Vertex AI API
# 2. IAM → Service Accounts → create with "Vertex AI User" role
# 3. Generate JSON key, save locally, point GOOGLE_APPLICATION_CREDENTIALS at it
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Azure OpenAI ─────────────────────────────────────────
# 1. Azure Portal → Create Azure OpenAI resource
# 2. Resource → Keys and Endpoint → copy KEY 1 and Endpoint
# 3. Azure OpenAI Studio → Deployments → deploy gpt-35-turbo
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo
AZURE_OPENAI_API_VERSION=2024-02-01
